# Development files
.git/
.gitignore
.npmignore
.eslintrc
.prettierrc
.github/
vitest.config.js
gh-pages

# Test files
coverage/
*.test.js

# Source code (consumers use dist/, but per-module READMEs are included separately
# via package.json `files` because they ARE the canonical agent reference for each module)
src/**/*.ts
src/**/*.tsx
src/**/*.js
src/**/*.test.ts
src/**/*.spec.ts

# Old docs/ folder (replaced by AGENTS.md + llms.txt at the package root)
docs/

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Dependencies
node_modules/

# Build files (if any)
build/