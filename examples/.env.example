# @bloomneo/appkit — canonical environment template
#
# Copy this file to `.env` in your project root, then fill in real values.
# Every framework-owned variable uses the BLOOM_ prefix; everything else is
# treated as application config by the config module.
#
# Generate secrets with:
#   openssl rand -base64 32        # 32-byte base64 (auth / CSRF)
#   openssl rand -hex 32           # 64-char hex (encryption)

# ──────────────────────────────────────────────────────────────────────
# REQUIRED for production
# ──────────────────────────────────────────────────────────────────────

# JWT signing key for authClass.get().generateLoginToken() / verifyToken()
# Minimum 32 characters.
BLOOM_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Primary database connection string (Prisma or Mongoose — auto-detected
# from protocol). Used by databaseClass.get() and databaseClass.getTenants().
DATABASE_URL=postgresql://user:pass@localhost:5432/myapp

# CSRF signing key for securityClass.get().forms().
# Falls back to BLOOM_AUTH_SECRET if unset. Minimum 32 characters.
BLOOM_SECURITY_CSRF_SECRET=replace-me-with-openssl-rand-base64-32

# AES-256-GCM key for securityClass.get().encrypt() / decrypt().
# Exactly 64 hex characters (32 bytes). Generate with
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# or with securityClass.generateKey().
BLOOM_SECURITY_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — auto-scaling kicks in when set
# ──────────────────────────────────────────────────────────────────────

# Distributed cache + events + queue. When unset, all three fall back to
# their in-process Memory transports.
# REDIS_URL=redis://localhost:6379

# Cloud storage (local disk by default)
# AWS_S3_BUCKET=my-bucket
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Cloudflare R2 (alternative to S3)
# R2_BUCKET=my-bucket
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...

# Real email (console transport by default)
# RESEND_API_KEY=re_...
#  — or —
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...

# Multi-tenant row-level filtering for databaseClass.get(req).
# When set, database clients auto-filter by tenant_id detected from the
# request (x-tenant-id header / req.user.tenant_id / subdomain / query).
# BLOOM_DB_TENANT=auto

# Per-organization connection strings for databaseClass.org('<id>').get().
# Use the org ID uppercased. The {org} placeholder in DATABASE_URL also works.
# ORG_ACME=postgresql://acme.db.example.com/prod
# ORG_GLOBEX=postgresql://globex.db.example.com/prod

# Monorepo app discovery (only used by multi-app setups)
# BLOOM_APPS_DIR=apps

# Logger transports (console-only by default)
# BLOOM_LOGGER_FILE_PATH=/var/log/myapp.log
# BLOOM_LOGGER_HTTP_URL=https://logs.example.com/ingest
# BLOOM_LOGGER_WEBHOOK_URL=https://hooks.slack.com/services/...

# Service identification (attached to every log record)
# BLOOM_SERVICE_NAME=myapp
# BLOOM_SERVICE_VERSION=1.0.0

# Application config (non-BLOOM_ vars are exposed via configClass.get())
# DATABASE_POOL_SIZE=10        →  config.get('database.pool.size')
# FEATURES_BETA_ENABLED=true   →  config.get('features.beta.enabled')
